# =============================================================================
# EarningsSignal Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API key.
# .env is gitignored and will never be committed.

# LLM Provider (currently only siliconflow is supported)
LLM_PROVIDER=siliconflow

# SiliconFlow API key (get one at https://siliconflow.cn)
SILICONFLOW_API_KEY=your_api_key_here

# Model name (DeepSeek V4 Flash is the default; V3 and Qwen also supported)
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Optional: custom Python interpreter path (default: sys.executable)
# QUANT_PYTHON=python
